{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "inlineSources": false,
    "inlineSourceMap": false,
    "rewriteRelativeImportExtensions": true
  },
  "include": ["src"],
  "exclude": ["src/index.ts", "test", "node_modules"]
}